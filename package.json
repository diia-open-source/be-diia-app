{
    "name": "@diia-inhouse/diia-app",
    "version": "18.1.0",
    "description": "Application package with IoC container",
    "main": "dist/index.js",
    "types": "dist/types/index.d.ts",
    "repository": "https://github.com/diia-open-source/diia-app.git",
    "author": "Diia",
    "license": "SEE LICENSE IN LICENSE.md",
    "files": [
        "dist",
        "src"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "tsc",
        "prepare": "ts-patch install -s && npm run build",
        "genproto": "npm run genproto-test",
        "semantic-release": "semantic-release",
        "start": "npm run build && node dist/index.js",
        "lint": "eslint --ext .ts . && prettier --check .",
        "lint-fix": "eslint '*/**/*.{js,ts}' --fix && prettier --write .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "pretest": "npm run genproto-test && npm run build-test",
        "test": "NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" jest",
        "test:unit": "npm run test --selectProjects unit --",
        "test:integration": "npm run test --selectProjects integration --",
        "test:coverage": "npm run test --coverage",
        "find-circulars": "madge --circular --extensions ts ./",
        "genproto-test": "genproto --rootDir tests/integration/proto --outputDir tests/integration/generated --generateClient=true",
        "build-test": "rimraf tests/dist && npm run build -- --project tests/tsconfig.json --noEmit false --outDir tests/dist"
    },
    "dependencies": {
        "@grpc/grpc-js": "1.10.7",
        "@grpc/proto-loader": "0.7.13",
        "@grpc/reflection": "1.0.4",
        "@opentelemetry/api": "1.9.0",
        "@opentelemetry/auto-instrumentations-node": "0.47.1",
        "@opentelemetry/core": "1.25.0",
        "@opentelemetry/exporter-trace-otlp-grpc": "0.52.0",
        "@opentelemetry/instrumentation": "0.52.0",
        "@opentelemetry/resources": "1.25.0",
        "@opentelemetry/sdk-trace-base": "1.25.0",
        "@opentelemetry/sdk-trace-node": "1.25.0",
        "@opentelemetry/semantic-conventions": "1.25.0",
        "@types/dotenv-flow": "3.3.3",
        "awilix": "10.0.2",
        "cookie-parser": "1.4.6",
        "dotenv-flow": "3.3.0",
        "glob": "10.4.1",
        "lodash": "4.17.21",
        "moleculer": "0.14.33",
        "moleculer-web": "0.10.7",
        "nats": "2.26.0",
        "nice-grpc": "2.1.8",
        "nice-grpc-client-middleware-deadline": "2.0.11",
        "pluralize": "8.0.0",
        "protobufjs": "^7.2.5",
        "ts-patch": "2.1.0"
    },
    "peerDependencies": {
        "@diia-inhouse/crypto": ">=1.8.1",
        "@diia-inhouse/db": ">=4.8.0",
        "@diia-inhouse/diia-logger": ">=3.0.0",
        "@diia-inhouse/diia-metrics": ">=3.12.0",
        "@diia-inhouse/diia-queue": ">=6.3.2",
        "@diia-inhouse/env": ">=1.10.2",
        "@diia-inhouse/errors": ">=1.7.0",
        "@diia-inhouse/features": ">=2.1.0",
        "@diia-inhouse/healthcheck": ">=1.7.0",
        "@diia-inhouse/redis": ">=2.2.1",
        "@diia-inhouse/types": ">=6.30.0",
        "@diia-inhouse/utils": ">=2.29.0",
        "@diia-inhouse/validators": ">=1.5.0"
    },
    "peerDependenciesMeta": {
        "@diia-inhouse/diia-logger": {
            "optional": true
        },
        "@diia-inhouse/redis": {
            "optional": true
        },
        "@diia-inhouse/diia-queue": {
            "optional": true
        },
        "@diia-inhouse/healthcheck": {
            "optional": true
        },
        "@diia-inhouse/db": {
            "optional": true
        },
        "@diia-inhouse/crypto": {
            "optional": true
        },
        "@diia-inhouse/features": {
            "optional": true
        }
    },
    "devDependencies": {
        "@diia-inhouse/configs": "1.32.0",
        "@diia-inhouse/crypto": "1.11.0",
        "@diia-inhouse/db": "4.9.0",
        "@diia-inhouse/diia-logger": "3.0.0",
        "@diia-inhouse/diia-metrics": "3.12.0",
        "@diia-inhouse/diia-queue": "7.3.0",
        "@diia-inhouse/env": "1.16.0",
        "@diia-inhouse/errors": "1.10.0",
        "@diia-inhouse/eslint-config": "5.1.0",
        "@diia-inhouse/eslint-plugin": "1.6.0",
        "@diia-inhouse/features": "2.1.0",
        "@diia-inhouse/genproto": "1.14.0",
        "@diia-inhouse/healthcheck": "1.12.0",
        "@diia-inhouse/redis": "2.12.0",
        "@diia-inhouse/test": "6.3.1",
        "@diia-inhouse/types": "6.30.0",
        "@diia-inhouse/utils": "3.5.0",
        "@diia-inhouse/validators": "1.17.0",
        "@opentelemetry/instrumentation-amqplib": "0.38.0",
        "@opentelemetry/instrumentation-http": "0.52.0",
        "@opentelemetry/otlp-grpc-exporter-base": "0.52.0",
        "@types/cookie-parser": "1.4.7",
        "@types/lodash": "4.17.5",
        "@types/node": "20.14.5",
        "@types/pluralize": "0.0.33",
        "eslint": "8.57.0",
        "lockfile-lint": "4.14.0",
        "madge": "7.0.0",
        "prettier": "3.3.2",
        "type-fest": "4.8.2",
        "typescript": "5.4.5"
    },
    "jest": {
        "preset": "@diia-inhouse/configs/dist/jest"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package"
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "eslintConfig": {
        "extends": "@diia-inhouse/eslint-config",
        "overrides": [
            {
                "files": [
                    "*.ts"
                ],
                "parserOptions": {
                    "project": [
                        "./tsconfig.json",
                        "./tests/tsconfig.json"
                    ]
                }
            }
        ]
    },
    "prettier": "@diia-inhouse/eslint-config/prettier",
    "madge": {
        "tsConfig": "./tsconfig.json"
    }
}
