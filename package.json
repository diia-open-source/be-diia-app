{
    "name": "@diia-inhouse/diia-app",
    "version": "31.3.0",
    "description": "Application package with IoC container",
    "main": "dist/index.js",
    "types": "dist/types/index.d.ts",
    "repository": "https://github.com/diia-open-source/diia-app.git",
    "author": "Diia",
    "license": "SEE LICENSE IN LICENSE.md",
    "files": [
        "dist",
        "src",
        "proto"
    ],
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "tsc",
        "prepare": "ts-patch install -s && npm run build",
        "genproto": "npm run genproto-test",
        "semantic-release": "semantic-release",
        "start": "npm run build && node dist/index.js",
        "lint": "eslint . && prettier --check .",
        "lint-fix": "eslint . --fix && prettier --write .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "pretest": "npm run genproto-test",
        "test": "tsc --project tests/tsconfig.json && vitest run",
        "test:watch": "vitest watch",
        "find-circulars": "madge --circular --extensions ts ./",
        "genproto-test": "genproto --rootDir tests/integration/proto --outputDir tests/integration/generated --generateClient=true --entrypoint tests/integration/proto/test-service.proto"
    },
    "dependencies": {
        "@grpc/grpc-js": "1.14.3",
        "@grpc/proto-loader": "0.8.0",
        "@grpc/reflection": "1.0.4",
        "@opentelemetry/api": "1.9.0",
        "@opentelemetry/auto-instrumentations-node": "0.56.1",
        "@opentelemetry/core": "1.30.1",
        "@opentelemetry/exporter-trace-otlp-grpc": "0.57.2",
        "@opentelemetry/instrumentation": "0.57.2",
        "@opentelemetry/resources": "1.30.1",
        "@opentelemetry/sdk-trace-base": "1.30.1",
        "@opentelemetry/sdk-trace-node": "1.30.1",
        "@opentelemetry/semantic-conventions": "1.38.0",
        "@types/dotenv-flow": "3.3.3",
        "awilix": "12.0.5",
        "cookie-parser": "1.4.7",
        "dotenv-flow": "4.1.0",
        "glob": "11.1.0",
        "lodash": "4.17.23",
        "moleculer": "0.14.35",
        "moleculer-web": "0.10.8",
        "nats": "2.29.3",
        "nice-grpc": "2.1.14",
        "nice-grpc-client-middleware-deadline": "2.0.17",
        "p-timeout": "4.1.0",
        "pluralize": "8.0.0",
        "protobufjs": "7.5.4",
        "ts-patch": "3.3.0"
    },
    "peerDependencies": {
        "@diia-inhouse/crypto": ">=1.8.1",
        "@diia-inhouse/db": ">=10.0.0",
        "@diia-inhouse/diia-logger": ">=3.0.0",
        "@diia-inhouse/diia-metrics": ">=6.1.1",
        "@diia-inhouse/diia-queue": ">=9.0.0",
        "@diia-inhouse/env": ">=1.18.0",
        "@diia-inhouse/errors": ">=1.7.0",
        "@diia-inhouse/features": ">=2.1.0",
        "@diia-inhouse/healthcheck": ">=1.13.0",
        "@diia-inhouse/redis": ">=2.2.1",
        "@diia-inhouse/types": ">=7.34.1",
        "@diia-inhouse/utils": ">=4.34.0",
        "@diia-inhouse/validators": ">=1.22.0"
    },
    "peerDependenciesMeta": {
        "@diia-inhouse/diia-logger": {
            "optional": true
        },
        "@diia-inhouse/redis": {
            "optional": true
        },
        "@diia-inhouse/diia-queue": {
            "optional": true
        },
        "@diia-inhouse/healthcheck": {
            "optional": true
        },
        "@diia-inhouse/db": {
            "optional": true
        },
        "@diia-inhouse/crypto": {
            "optional": true
        },
        "@diia-inhouse/features": {
            "optional": true
        }
    },
    "devDependencies": {
        "@diia-inhouse/configs": "6.1.1",
        "@diia-inhouse/crypto": "1.20.0",
        "@diia-inhouse/db": "10.8.2",
        "@diia-inhouse/diia-logger": "3.16.4",
        "@diia-inhouse/diia-metrics": "6.5.0",
        "@diia-inhouse/diia-queue": "13.2.1",
        "@diia-inhouse/env": "2.8.1",
        "@diia-inhouse/errors": "1.18.2",
        "@diia-inhouse/eslint-config": "8.4.0",
        "@diia-inhouse/features": "2.7.2",
        "@diia-inhouse/genproto": "3.2.1",
        "@diia-inhouse/healthcheck": "1.17.1",
        "@diia-inhouse/redis": "2.29.0",
        "@diia-inhouse/test": "7.3.2",
        "@diia-inhouse/types": "11.5.0",
        "@diia-inhouse/utils": "5.3.1",
        "@diia-inhouse/validators": "1.28.4",
        "@opentelemetry/instrumentation-amqplib": "0.46.1",
        "@opentelemetry/instrumentation-http": "0.57.2",
        "@opentelemetry/otlp-grpc-exporter-base": "0.57.2",
        "@types/cookie-parser": "1.4.10",
        "@types/lodash": "4.17.24",
        "@types/node": "22.19.15",
        "@types/pluralize": "0.0.33",
        "@vitest/coverage-v8": "4.1.0",
        "@vitest/ui": "4.1.0",
        "eslint": "9.39.4",
        "lockfile-lint": "4.14.1",
        "madge": "8.0.0",
        "prettier": "3.8.1",
        "rimraf": "6.1.3",
        "type-fest": "4.41.0",
        "typescript": "5.9.3",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.1.0",
        "vitest-mock-extended": "3.1.0"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package"
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "prettier": "@diia-inhouse/eslint-config/prettier",
    "madge": {
        "tsConfig": "./tsconfig.json"
    }
}
